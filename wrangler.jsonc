{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "tm-knowledge-mcp",
	"main": "src/index.ts",
	"compatibility_date": "2025-03-10",
	"compatibility_flags": [
		"nodejs_compat"
	],
	/**
	 * Secrets (set via `wrangler secret put <NAME>`):
	 *   KB_DB_CONNECTION    — Supabase transaction-pooler connection string (kb_service role)
	 *   GEMINI_API_KEY      — Google AI Studio key for gemini-embedding-001
	 *   COOKIE_ENCRYPTION_KEY — random string for signing approval cookies
	 */
	"migrations": [
		{
			"new_sqlite_classes": [
				"MyMCP"
			],
			"tag": "v1"
		}
	],
	"durable_objects": {
		"bindings": [
			{
				"class_name": "MyMCP",
				"name": "MCP_OBJECT"
			}
		]
	},
	"kv_namespaces": [
		{
			"binding": "OAUTH_KV",
			"id": "<Add-KV-ID>"
		}
	],
	"observability": {
		"enabled": true
	},
	"dev": {
		"port": 8788
	},
	"upload_source_maps": true
}
